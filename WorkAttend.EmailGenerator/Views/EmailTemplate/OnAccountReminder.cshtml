@model WorkAttend.EmailGenerator.Models.AccReminderPassModel

<!doctype html>
<html lang="en">
<head>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="">
    <meta name="author" content="">
    <title>On Account Amount Reminder</title>

</head>

<body style="margin: 0; padding: 0;">

    <table border="0" cellpadding="0" cellspacing="0" width="100%">

        <tr>
            <td>

                <table width="900" border="0" cellpadding="0" cellspacing="0" valign="middle" align="center">
                    <tbody>

                        <tr> <td colspan="3">&nbsp;</td> </tr>
                        <tr> <td colspan="3">&nbsp;</td> </tr>
                        <tr> <td colspan="3">&nbsp;</td> </tr>


                        <tr>
                            <td colspan="3" style="text-align: center;">
                                <a href="#"><img src="https://data.WorkAttend.com/resources/email_image/buzztill-logo.png" alt="Buzztill Logo" width="120px"></a>
                            </td>
                        </tr>

                        <tr>
                            <td colspan="3">&nbsp;</td>
                        </tr>


                        <tr style="background-color: #f1f1f1;">

                            <td width="55">&nbsp;</td>

                            <td width="476">
                                <br><br><br>
                                <h2 style="color: #555050; font-size: 30px;margin: 0; font-family:arial;">
                                    On Account Amount Reminder
                                </h2>
                                <br>
                                <p style="color: #4a4a4a; font-size: 15px; font-family: arial;line-height: 22px;margin: 0;">Hi @Model.FirstName @Model.LastName</p>
                                <br>
                                <p style="color: #4a4a4a; font-size: 15px; font-family: arial;line-height: 22px;margin: 0;">
                                    Hope you're doing well, It is for the reminder that you have the following amount remaining to pay.
                                </p>

                                <br>
                                <p style="color: #4a4a4a; font-size: 15px; font-family: arial;line-height: 22px;margin: 0;">On Account Amount is <strong>EUR @Model.AccountCredit</strong></p>

                                <br>
                                @*   <a href="https://www.google.com/search?client=opera&q=swift+back+light+cover&sourceid=opera&ie=UTF-8&oe=UTF-8" target="_blank">
                                <img src="images/PayNow-btn.png" alt="" width="153px" height="52px;">
                                </a>*@

                                <br>
                                <br>
                                <p style="color: #4a4a4a; font-size: 15px; font-family: arial;line-height: 22px;margin: 0;">Thanks,</p>
                                <br>
                                <p style="color: #4a4a4a; font-size: 15px; font-family: arial;line-height: 22px;margin: 0;">Store: @Model.StoreName</p>
                                <p style="color: #4a4a4a; font-size: 15px; font-family: arial;line-height: 22px;margin: 0;">The Dakar POS Team</p>
                                <br><br><br>

                            </td>

                            <td width="369" valign="middle">
                                <img src="https://data.WorkAttend.com/resources/email_image/loan-back.png" alt="" style="width: 400px; max-width: 600px; height: auto; margin: auto; display: block;">
                            </td>
                        </tr>

                        <tr>
                            <td colspan="3">&nbsp;</td>
                        </tr>

                        <tr>
                            <td colspan="3">
                                <p style="color: #4a4a4a; font-size: 15px; font-family: arial;line-height: 22px;margin: 0;">Copyright DAKAR POS ©2024</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </td>
        </tr>





    </table>










</body>
</html>
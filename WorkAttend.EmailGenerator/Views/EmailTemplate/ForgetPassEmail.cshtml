@model WorkAttend.EmailGenerator.Models.ForgetPassModel

<!doctype html>
<html lang="en">
<head>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="">
    <meta name="author" content="">
    <title>Forgot Password</title>

</head>

<body style="margin: 0; padding: 0;">

    <table border="0" cellpadding="0" cellspacing="0" width="100%">

        <tr>
            <td>

                <table width="900" border="0" cellpadding="0" cellspacing="0" valign="middle" align="center">
                    <tbody>

                        <tr> <td colspan="3">&nbsp;</td> </tr>
                        <tr> <td colspan="3">&nbsp;</td> </tr>
                        <tr> <td colspan="3">&nbsp;</td> </tr>


                        <tr>
                            <td colspan="3" style="text-align: center;">
                                <a href="#"><img src="https://data.WorkAttend.com/resources/email_image/buzztill-logo.png" alt="Buzztill Logo" width="120px"></a>
                            </td>
                        </tr>

                        <tr>
                            <td colspan="3">&nbsp;</td>
                        </tr>


                        <tr style="background-color: #f1f1f1; background-image: url(https://data.WorkAttend.com/resources/email_image/bg.jpg);">

                            <td width="56">&nbsp;</td>

                            <td width="521">
                                <br><br><br>
                                <h2 style="color: #555050; font-size: 30px;margin: 0; font-family:arial;">Forgot Password</h2>
                                <br>
                                <p style="color: #4a4a4a; font-size: 15px; font-family: arial;line-height: 22px;margin: 0;">Hello @Model.FirstName @Model.LastName,</p>
                                <br>
                                <p style="color: #4a4a4a; font-size: 15px; font-family: arial;line-height: 22px;margin: 0;">You recently requested that you forget your password. This was your recent password:</p>
                                <br>
                                <p style="color: #4a4a4a; font-size: 15px; font-family: arial;line-height: 22px; font-weight: bold;margin: 0;">Password: @Model.PassCode</p>
                                <br>
                                <p style="color: #4a4a4a; font-size: 15px; font-family: arial;line-height: 22px;margin: 0;">If you didn't request this, you can ignore this email – your password will remain the same.</p>

                                <br>
                                <p style="color: #4a4a4a; font-size: 15px; font-family: arial;line-height: 22px;margin: 0;">BuzzTill POS 2024</p>
                                <br><br><br>

                            </td>

                            <td width="325" valign="middle">
                                <img src="https://data.WorkAttend.com/resources/email_image/ForgotPassword.png" alt="" style="width: 300px; max-width: 600px; height: auto; margin: auto; display: block;">
                            </td>

                        </tr>

                        <tr>
                            <td colspan="3">&nbsp;</td>
                        </tr>


                        <tr>
                            <td colspan="3">
                                <p style="color: #4a4a4a; font-size: 15px; font-family: arial;line-height: 22px;margin: 0;">Copyright DAKAR POS ©2024</p>
                            </td>
                        </tr>



                    </tbody>
                </table>


            </td>
        </tr>





    </table>










</body>
</html>